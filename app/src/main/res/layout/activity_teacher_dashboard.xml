<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Welcome Text -->
        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teacher Dashboard"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_blue_dark"
            android:layout_marginBottom="32dp"/>

        <!-- Teacher Actions -->
        <Button
            android:id="@+id/manageStudentsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Students"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/manageCoursesBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Courses"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/uploadAssignmentBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Assignment"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/publishNoticeBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Publish Notice"
            android:layout_marginBottom="24dp"/>

        <!-- Logout -->
        <Button
            android:id="@+id/logoutBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white"/>
    </LinearLayout>
</ScrollView>
